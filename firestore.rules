rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    // User profile rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && incoming().keys().hasAll(['uid', 'email']) && incoming().uid == userId;
      allow update: if isOwner(userId) && incoming().diff(resource.data).affectedKeys().hasOnly(['displayName', 'photoURL', 'currency']);
    }

    // Transaction rules
    match /users/{userId}/transactions/{transactionId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && incoming().keys().hasAll(['amount', 'type', 'category', 'date', 'userId']) && incoming().userId == userId;
      allow update: if isOwner(userId) && incoming().userId == userId;
      allow delete: if isOwner(userId);
    }

    // Budget rules
    match /users/{userId}/budgets/{budgetId} {
      allow list, get: if isOwner(userId);
      allow create: if isOwner(userId) && incoming().keys().hasAll(['category', 'amount', 'month', 'userId']) && incoming().userId == userId;
      allow update: if isOwner(userId) && incoming().userId == userId;
      allow delete: if isOwner(userId);
    }
  }
}

# ─── Masroufi — Environment Variables ───────────────────────────────────────
# Copy this file to .env and fill in your Firebase project values.
# NEVER commit .env to git — add it to .gitignore
#
# Get these values from:
# Firebase Console → Project Settings → Your Apps → Web App → Config

VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# Optional — only if you use a named Firestore database (not "(default)")
# VITE_FIREBASE_FIRESTORE_DATABASE_ID=your_database_id

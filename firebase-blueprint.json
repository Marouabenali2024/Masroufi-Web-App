{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "currency": { "type": "string", "description": "User's preferred currency (e.g., TND)" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Financial transaction (Income or Expense)",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "category", "date"]
    },
    "Category": {
      "title": "Category",
      "description": "Expense/Income categories",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] }
      },
      "required": ["userId", "name", "type"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget for a specific category",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "month": { "type": "string", "description": "Format YYYY-MM" }
      },
      "required": ["userId", "category", "amount", "month"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Single user document"
    },
    "users/{userId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "User's individual transactions"
    },
    "users/{userId}/categories/{categoryId}": {
      "schema": "Category",
      "description": "User-specific categories (customizable)"
    },
    "users/{userId}/budgets/{budgetId}": {
      "schema": "Budget",
      "description": "User's monthly category budgets"
    }
  }
}
